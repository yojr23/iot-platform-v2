# Orchestracion local para Docker Compose.
# Backend real: ver `back/.env.example`
# Frontend real: ver `front/.env.example`

BACK_PORT=8000
FRONT_PORT=5173
MYSQL_PORT=3306
REDIS_PORT=6379
COMPOSE_PROJECT_NAME=iotplatformv2

DB_CONNECTION=mysql
DB_DATABASE=iot_platform
DB_USERNAME=iot_user
DB_PASSWORD=iot_password
DB_ROOT_PASSWORD=root_password

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database
INGESTION_SERVICE_TOKEN=
INGESTION_RAW_EVENTS_STREAM=iot.raw-events

VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=
VITE_PUSHER_FORCE_TLS=true
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=
VITE_PUSHER_SCHEME=https
